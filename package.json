{
  "name": "@xtruder/opencode-claude-max-plugin",
  "version": "0.4.1",
  "description": "OpenCode plugin for Claude Max/Pro subscription via @anthropic-ai/sdk - uses Claude Code OAuth credentials",
  "keywords": [
    "ai-sdk",
    "anthropic",
    "claude",
    "opencode",
    "provider"
  ],
  "license": "MIT",
  "files": [
    "build",
    "src/tui.tsx",
    "src/usage.ts",
    "src/credentials.ts"
  ],
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    },
    "./server": {
      "import": "./build/server.js",
      "config": {}
    },
    "./tui": {
      "import": "./src/tui.tsx",
      "config": {
        "enabled": "true",
        "sidebar": "true",
        "poll_interval": "60"
      }
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/server.ts --outdir ./build --target node --format esm --packages external && bun x tsc --emitDeclarationOnly --declaration --outDir build",
    "dev": "bun run dev:config && bun build ./src/index.ts --outdir ./build --target node --format esm --packages external --watch",
    "dev:config": "bun scripts/dev-config.ts",
    "test": "bun test --concurrency 1 src/*.test.ts",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.104.1",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "3.0.8",
    "@ai-sdk/provider-utils": "3.0.2",
    "@opencode-ai/plugin": "1.15.11",
    "@opentui/solid": "^0.1.96",
    "ai": "^6.0.146",
    "bun-types": "^1.3.11",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=2.0.0",
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    },
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint && bun run format:check"
  },
  "engines": {
    "opencode": ">=1.3.13"
  }
}
