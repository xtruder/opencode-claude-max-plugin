{
  "name": "opencode-anthropic-sdk-provider",
  "version": "0.1.0",
  "description": "OpenCode provider that uses @anthropic-ai/sdk directly for Claude model access",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./build --target node --format esm --packages external && bun x tsc --emitDeclarationOnly --declaration --outDir build",
    "test": "bun run src/test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.74.0"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=2.0.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "2.0.1",
    "@ai-sdk/provider-utils": "3.0.2",
    "ai": "5.0.124",
    "bun-types": "^1.3.11",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "opencode",
    "anthropic",
    "claude",
    "ai-sdk",
    "provider"
  ],
  "license": "MIT"
}
