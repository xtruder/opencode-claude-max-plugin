{
  "name": "@xtruder/opencode-claude-max-plugin",
  "version": "0.1.5",
  "description": "OpenCode plugin for Claude Max/Pro subscription via @anthropic-ai/sdk - uses Claude Code OAuth credentials",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    },
    "./agent": {
      "import": "./build/agent-index.js",
      "types": "./build/agent-index.d.ts"
    }
  },
  "bin": {
    "claude-usage": "build/usage-cli.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts ./src/agent-index.ts ./src/usage-cli.ts --outdir ./build --target node --format esm --packages external && bun x tsc --emitDeclarationOnly --declaration --outDir build",
    "test": "bun run src/test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@anthropic-ai/sdk": "0.74.0"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=2.0.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "2.0.1",
    "@ai-sdk/provider-utils": "3.0.2",
    "ai": "5.0.124",
    "bun-types": "^1.3.11",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "opencode",
    "anthropic",
    "claude",
    "ai-sdk",
    "provider"
  ],
  "license": "MIT"
}
